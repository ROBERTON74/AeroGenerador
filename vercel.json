{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/esios-api/:path*",
      "destination": "/api/esios?path=:path*"
    },
    {
      "source": "/ree-api/:path*",
      "destination": "/api/ree?path=:path*"
    },
    {
      "source": "/open-meteo-api/:path*",
      "destination": "/api/open-meteo?path=:path*"
    }
  ]
}
